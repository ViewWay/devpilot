#!/usr/bin/env bash
# pre-push: Scan for accidental secrets before pushing to remote

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

FOUND=0

# Check staged + uncommitted tracked files
FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null; git diff --name-only 2>/dev/null)
FILES=$(echo "$FILES" | sort -u | grep -v '^$' || true)

if [ -n "$FILES" ]; then
  # OpenAI/Anthropic real keys (20+ chars after sk-)
  if echo "$FILES" | xargs grep -E 'sk-[a-zA-Z0-9]{20,}' 2>/dev/null; then
    printf "%b[BLOCKED] Possible OpenAI/Anthropic API key detected%b\n" "$RED" "$NC"
    FOUND=1
  fi
  # GitHub PATs
  if echo "$FILES" | xargs grep -E 'ghp_[a-zA-Z0-9]{30,}' 2>/dev/null; then
    printf "%b[BLOCKED] Possible GitHub PAT detected%b\n" "$RED" "$NC"
    FOUND=1
  fi
  # GitHub OAuth
  if echo "$FILES" | xargs grep -E 'gho_[a-zA-Z0-9]{30,}' 2>/dev/null; then
    printf "%b[BLOCKED] Possible GitHub OAuth token detected%b\n" "$RED" "$NC"
    FOUND=1
  fi
  # Slack tokens
  if echo "$FILES" | xargs grep -E 'xox[bposa]-[a-zA-Z0-9-]{20,}' 2>/dev/null; then
    printf "%b[BLOCKED] Possible Slack token detected%b\n" "$RED" "$NC"
    FOUND=1
  fi
  # AWS access keys
  if echo "$FILES" | xargs grep -E 'AKIA[A-Z0-9]{16}' 2>/dev/null; then
    printf "%b[BLOCKED] Possible AWS access key detected%b\n" "$RED" "$NC"
    FOUND=1
  fi
  # Google API keys
  if echo "$FILES" | xargs grep -E 'AIza[a-zA-Z0-9_-]{35}' 2>/dev/null; then
    printf "%b[BLOCKED] Possible Google API key detected%b\n" "$RED" "$NC"
    FOUND=1
  fi
  # Private keys
  if echo "$FILES" | xargs grep -l 'BEGIN.*PRIVATE KEY' 2>/dev/null; then
    printf "%b[BLOCKED] Possible private key detected%b\n" "$RED" "$NC"
    FOUND=1
  fi
fi

# Check commit history being pushed
REMOTE_SHA=$(git rev-parse "@{push}" 2>/dev/null || echo "")
LOCAL_SHA=$(git rev-parse HEAD)

if [ -n "$REMOTE_SHA" ] && [ "$LOCAL_SHA" != "$REMOTE_SHA" ]; then
  DIFF=$(git log "${REMOTE_SHA}..${LOCAL_SHA}" -p 2>/dev/null || true)
  if [ -n "$DIFF" ]; then
    if printf '%s' "$DIFF" | grep -qE 'sk-[a-zA-Z0-9]{20,}'; then
      printf "%b[BLOCKED] API key found in commit history%b\n" "$RED" "$NC"
      FOUND=1
    fi
    if printf '%s' "$DIFF" | grep -qE 'ghp_[a-zA-Z0-9]{30,}'; then
      printf "%b[BLOCKED] GitHub PAT found in commit history%b\n" "$RED" "$NC"
      FOUND=1
    fi
    if printf '%s' "$DIFF" | grep -qE 'AKIA[A-Z0-9]{16}'; then
      printf "%b[BLOCKED] AWS key found in commit history%b\n" "$RED" "$NC"
      FOUND=1
    fi
  fi
fi

if [ "$FOUND" -eq 1 ]; then
  printf "\n%bPush blocked: possible secrets detected.%b\n" "$RED" "$NC"
  printf "If false positive, bypass with: git push --no-verify\n"
  exit 1
fi

printf "%bNo secrets detected in push%b\n" "$GREEN" "$NC"
exit 0
